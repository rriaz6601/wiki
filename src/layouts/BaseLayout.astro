---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rana Riaz | Engineer",
  description = "Engineer focused on software, systems, infrastructure, networking, and practical problem-solving.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <slot />
  </body>
</html>
