---
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
  { label: "Overview", href: "#overview" },
  { label: "Capabilities", href: "#capabilities" },
  { label: "Blueprint", href: "#blueprint" },
  { label: "Current focus", href: "#current-focus" },
];

const metrics = [
  { value: "8+", label: "technical domains I move through comfortably" },
  { value: "0 drama", label: "preferred operating mode during delivery" },
  { value: "1 system", label: "product, infra, and ops viewed together" },
];

const pillars = [
  {
    title: "Software systems",
    description: "From rough requirements to clean implementations that can survive real users, real traffic, and real maintenance.",
    accent: "sky",
  },
  {
    title: "Infrastructure and deployment",
    description: "Containers, hosting, release flows, and environments that stay understandable instead of turning into ritual.",
    accent: "violet",
  },
  {
    title: "Networking and troubleshooting",
    description: "Remote access, routing, connectivity, and the kind of debugging work that usually sits between teams.",
    accent: "emerald",
  },
  {
    title: "Automation and integration",
    description: "Connecting tools, shaping repeatable workflows, and removing the expensive manual edges from operations.",
    accent: "amber",
  },
];

const principles = [
  "Make the system understandable before making it clever.",
  "Prefer dependable flows over impressive but fragile complexity.",
  "Stay close to deployment reality while designing the implementation.",
  "Use taste to simplify, not to over-decorate.",
];

const blueprint = [
  {
    phase: "Discover",
    detail: "Clarify the problem, the environment, and the operational constraints before committing to architecture.",
  },
  {
    phase: "Design",
    detail: "Shape the implementation path so product, infrastructure, and reliability work together instead of fighting later.",
  },
  {
    phase: "Deliver",
    detail: "Build calmly, integrate carefully, and keep the result legible for the next person who has to touch it.",
  },
  {
    phase: "Stabilize",
    detail: "Measure the rough edges, reduce the noisy failure modes, and leave the system easier to run than before.",
  },
];

const signals = [
  { label: "Works well with", value: "Astro, containers, Linux, APIs, deployment tooling" },
  { label: "Thinks in", value: "systems, trade-offs, interfaces, and operational reality" },
  { label: "Optimizes for", value: "clarity, resilience, momentum, and maintainability" },
];

const currentFocus = [
  "Building self-hosted platforms that feel deliberate rather than improvised.",
  "Designing deployment paths that reduce friction between shipping and operating.",
  "Improving network-aware systems where infrastructure details shape the product experience.",
  "Creating calmer technical foundations for teams that need practical progress.",
];

const knowledgeMap = [
  "Application architecture",
  "Deployment pipelines",
  "Docker ecosystems",
  "Linux operations",
  "Private networking",
  "Systems integration",
  "Reliability thinking",
  "Root-cause troubleshooting",
];
---

<BaseLayout
  title="Rana Riaz | Systems Wiki"
  description="A polished systems-oriented landing page for Rana Riaz covering software, infrastructure, networking, automation, and delivery thinking."
>
  <main class="page-shell">
    <div class="ambient ambient-one"></div>
    <div class="ambient ambient-two"></div>
    <div class="grid-overlay"></div>

    <section class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-5 pb-16 pt-6 sm:px-8 lg:px-10">
      <header class="glass-panel sticky top-4 z-20 flex flex-wrap items-center justify-between gap-4 rounded-full px-5 py-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.36em] text-sky-200/80">Rana Riaz</p>
          <p class="mt-1 text-sm text-slate-300">Systems-minded engineer with a wide technical span.</p>
        </div>

        <nav aria-label="Primary" class="flex flex-wrap items-center gap-2 text-sm text-slate-200/90">
          {navItems.map((item) => (
            <a class="nav-chip" href={item.href}>{item.label}</a>
          ))}
        </nav>
      </header>

      <section id="overview" class="relative mt-8 grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
        <article class="feature-panel overflow-hidden p-8 sm:p-10 lg:p-12">
          <div class="flex flex-wrap items-center gap-3">
            <span class="badge badge-sky">Personal wiki</span>
            <span class="badge badge-white">Software + infrastructure + networks</span>
          </div>

          <h1 class="mt-7 max-w-4xl text-4xl font-semibold leading-[1.05] text-white sm:text-6xl xl:text-7xl">
            A sharper, calmer way to present broad technical depth.
          </h1>

          <p class="mt-6 max-w-3xl text-base leading-8 text-slate-300 sm:text-lg">
            I work across software engineering, deployment, automation, Linux systems, networking, and debugging. This page is
            designed less like a business card and more like a map of how I think, build, and stabilize systems.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#capabilities" class="button-primary">Explore capabilities</a>
            <a href="#current-focus" class="button-secondary">See current focus</a>
          </div>

          <div class="mt-10 grid gap-4 md:grid-cols-3">
            {metrics.map((metric) => (
              <div class="stat-card">
                <div class="text-2xl font-semibold text-white sm:text-3xl">{metric.value}</div>
                <p class="mt-2 text-sm leading-6 text-slate-300">{metric.label}</p>
              </div>
            ))}
          </div>
        </article>

        <aside class="space-y-6">
          <section class="glass-panel p-7">
            <p class="section-kicker">Operating profile</p>
            <h2 class="mt-4 text-2xl font-semibold text-white">Useful range, not vague generalism.</h2>
            <p class="mt-4 text-sm leading-7 text-slate-300">
              The value is not just knowing a lot of adjacent topics. It is being able to move between them without losing context,
              and without making the result feel stitched together.
            </p>
            <div class="mt-6 space-y-3">
              {signals.map((signal) => (
                <div class="rounded-3xl border border-white/10 bg-white/5 px-4 py-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">{signal.label}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-200">{signal.value}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="glass-panel p-7">
            <p class="section-kicker">Field note</p>
            <blockquote class="mt-4 text-lg leading-8 text-slate-100">
              “The best systems feel composed: clear enough to read, strong enough to operate, and calm enough to trust.”
            </blockquote>
          </section>
        </aside>
      </section>

      <section id="capabilities" class="mt-6 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <article class="glass-panel p-8 sm:p-10">
          <p class="section-kicker">Capabilities</p>
          <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">Where I usually create leverage.</h2>
          <p class="mt-5 max-w-2xl text-base leading-8 text-slate-300">
            I am most useful when the work crosses boundaries: product meets infrastructure, code meets deployment, or a messy issue
            spans multiple layers of the stack.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            {knowledgeMap.map((item) => (
              <span class="knowledge-chip">{item}</span>
            ))}
          </div>
        </article>

        <div class="grid gap-5 md:grid-cols-2">
          {pillars.map((pillar) => (
            <article class={`capability-card capability-card-${pillar.accent}`}>
              <div class="capability-dot"></div>
              <h3 class="mt-6 text-xl font-semibold text-white">{pillar.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{pillar.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="blueprint" class="mt-6 grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="glass-panel p-8 sm:p-10">
          <p class="section-kicker">Delivery blueprint</p>
          <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">How I take ambiguous work toward something stable.</h2>

          <div class="mt-8 space-y-5">
            {blueprint.map((step, index) => (
              <div class="timeline-row">
                <div class="timeline-index">0{index + 1}</div>
                <div>
                  <h3 class="text-lg font-semibold text-white">{step.phase}</h3>
                  <p class="mt-2 text-sm leading-7 text-slate-300">{step.detail}</p>
                </div>
              </div>
            ))}
          </div>
        </article>

        <article class="feature-panel p-8 sm:p-10">
          <p class="section-kicker">Design principles</p>
          <h2 class="mt-4 text-3xl font-semibold text-white">Taste, but operational.</h2>
          <ul class="mt-8 space-y-4">
            {principles.map((item) => (
              <li class="principle-row">
                <span class="principle-marker"></span>
                <span class="text-sm leading-7 text-slate-200">{item}</span>
              </li>
            ))}
          </ul>

          <div class="mt-8 rounded-[2rem] border border-white/10 bg-slate-950/55 p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-400">Why this page changed</p>
            <p class="mt-3 text-sm leading-7 text-slate-300">
              The old version had decent colors but too little structure. This redesign adds hierarchy, rhythm, richer content blocks,
              and a stronger sense of intent so the page feels curated instead of merely presentable.
            </p>
          </div>
        </article>
      </section>

      <section id="current-focus" class="mt-6 grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="feature-panel p-8 sm:p-10">
          <p class="section-kicker">Current focus</p>
          <h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">The themes I am pushing forward right now.</h2>
          <div class="mt-8 space-y-4">
            {currentFocus.map((item) => (
              <div class="focus-row">
                <span class="focus-icon">+</span>
                <p class="text-sm leading-7 text-slate-200">{item}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="glass-panel flex flex-col justify-between p-8 sm:p-10">
          <div>
            <p class="section-kicker">Closing snapshot</p>
            <h2 class="mt-4 text-3xl font-semibold text-white">Broad enough to connect the dots. Calm enough to ship the result.</h2>
            <p class="mt-5 text-sm leading-7 text-slate-300">
              If the work needs both taste and operational realism, I am usually at my best there. I like thoughtful systems, but I
              like dependable ones even more.
            </p>
          </div>

          <div class="mt-8 rounded-[2rem] border border-sky-300/15 bg-sky-300/10 p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-sky-200/80">Site direction</p>
            <p class="mt-3 text-sm leading-7 text-slate-100">
              Premium visual language, stronger content density, better navigation cues, and a layout that finally feels deliberate.
            </p>
          </div>
        </article>
      </section>
    </section>
  </main>
</BaseLayout>
